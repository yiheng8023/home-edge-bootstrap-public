# Portable proxy policy knobs. This file is shell-sourced by router scripts.
# Keep it non-secret: subscription URLs, tokens, and provider node lists stay local only.

# Leave HEAL_GROUP empty to auto-discover the main selectable proxy group from
# Mihomo's runtime group graph. Set it only when a provider/template uses a
# group layout the heuristic cannot identify safely.
: "${HEAL_GROUP:=}"
: "${HEAL_GROUP_MATCH_REGEX:=节点选择|代理选择|主选择|手动切换|自动选择|选择代理|全局选择|默认代理|国外|境外|(^|[^A-Za-z0-9])(PROXY|SELECT|Selector|Manual|Fallback|Auto|URL[ _.-]*Test|Load[ _.-]*Balance|Node[ _.-]*(Select|Selector|Choice)|Proxy[ _.-]*(Select|Selector|Choice)|Global[ _.-]*(Proxy|Select|Selector)|Main[ _.-]*(Proxy|Select|Selector)|Default[ _.-]*(Proxy|Select|Selector)|Outbound|Route[ _.-]*(Select|Selector))([^A-Za-z0-9]|$)}"
: "${HEAL_GROUP_EXCLUDE_REGEX:=广告|拦截|REJECT|DIRECT|直连|微软|Microsoft|苹果|Apple|谷歌|Google|FCM|电报|Telegram|Netflix|NETFLIX|Disney|YouTube|TikTok|媒体|Media|人工智能|(^|[^A-Za-z0-9])AI([^A-Za-z0-9]|$)|漏网|Final|MATCH}"
: "${HEAL_PROBE_URL:=https://cp.cloudflare.com/generate_204}"
: "${HEAL_DRY_RUN:=1}"
: "${HEAL_CRON_DRY_RUN:=1}"
: "${HEAL_LOG:=/tmp/self-heal.log}"
: "${HEAL_CRON_SCHEDULE:=*/3 * * * *}"
: "${HEAL_LOG_MAX_BYTES:=262144}"
: "${HEAL_STATE_DIR:=/tmp/home-edge-bootstrap}"
: "${HEAL_MAX_SWITCHES_PER_HOUR:=6}"
: "${HEAL_DELAY_PROBES:=2}"
: "${HEAL_DELAY_TIMEOUT_MS:=3000}"

# Keep routine self-heal at the main selector layer. Mihomo URLTest/Fallback
# groups should manage their own concrete-node choices unless a site-local
# override explicitly enables nested mutation for an unusual provider template.
: "${HEAL_MUTATE_NESTED_GROUPS:=0}"

# Route eligibility is region-neutral by default. Sites may opt into a region,
# provider tier, protocol, or other naming constraint without changing code.
: "${HEAL_ROUTE_REGION_REGEX:=}"
: "${HEAL_CANDIDATE_ROUTE_REGEX:=.}"
: "${HEAL_CANDIDATE_EXCLUDE_REGEX:=^(DIRECT|REJECT)$|广告|广告拦截|Ad[ _.-]*(Block|Reject)|Ads?[ _.-]*(Block|Reject)}"
: "${HEAL_PREFERRED_ROUTE_REGEX:=}"

# Optional role-group guardrails. These do not depend on one UI template: they
# match group names by role and choose a target from that group's own choices.
: "${HEAL_ROLE_GROUPS_ENABLED:=1}"
: "${HEAL_ROLE_AD_BLOCK_GROUP_REGEX:=广告|广告拦截|Ad[ _.-]*(Block|Reject)|Ads?[ _.-]*(Block|Reject)|Reject}"
: "${HEAL_ROLE_AD_BLOCK_TARGET:=REJECT}"
: "${HEAL_ROLE_ROUTE_GROUP_MATCH_REGEX:=}"
: "${HEAL_ROLE_ROUTE_TARGET_REGEX:=}"

# Local-only subscription settings. Put the actual URL in SUBSCRIPTION.local, not here.
: "${SUBSCRIPTION_FILE:=/jffs/home-edge-bootstrap/SUBSCRIPTION.local}"
: "${SUBSCRIPTION_CACHE:=/jffs/home-edge-bootstrap/cache/subscription.yaml}"
: "${SUBSCRIPTION_BACKUP_DIR:=/jffs/home-edge-bootstrap/backups/subscription}"
: "${SUBSCRIPTION_APPLY_PATH:=}"
: "${SUBSCRIPTION_RUNTIME_EVIDENCE:=/tmp/home-edge-subscription-runtime.evidence}"
: "${SUBSCRIPTION_RUNTIME_EVIDENCE_MAX_AGE_SEC:=300}"
: "${SUBSCRIPTION_RELOAD_CMD:=}"
: "${SUBSCRIPTION_DRY_RUN:=1}"
: "${SUBSCRIPTION_FETCH_PROXY:=}"
: "${SUBSCRIPTION_CONVERTER_BASE_URL:=}"
: "${SUBSCRIPTION_CONVERTER_TARGET:=clash}"
: "${SUBSCRIPTION_CONVERTER_CONFIG_URL:=}"
: "${SUBSCRIPTION_ALLOW_REMOTE_CONVERTER:=0}"
: "${SUBSCRIPTION_MIN_BYTES:=64}"
: "${SUBSCRIPTION_MAX_BACKUPS:=5}"
: "${SUBSCRIPTION_LOG_MAX_BYTES:=262144}"

# Site-local overrides survive kit redeploys. Use this for live toggles,
# explicit group names, local API secrets, or environment-specific paths.
for policy_local in \
  /jffs/home-edge-bootstrap/policy.local \
  /jffs/scripts/home-edge-policy.local
do
  [ -r "$policy_local" ] && . "$policy_local"
done

# Keep sourcing this policy successful when neither optional local override exists.
:
